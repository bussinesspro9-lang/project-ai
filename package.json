{
  "name": "@businesspro/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Business Pro - AI-driven social media automation platform",
  "workspaces": [
    "our-app",
    "api",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun:dev:*\"",
    "dev:api": "bun --filter api start:dev",
    "dev:web": "bun --filter my-v0-project dev",
    "dev:ai": "bun --filter @businesspro/ai dev",
    "dev:auth-ui": "bun --filter @businesspro/auth-ui dev",
    "app:dev": "cd our-app ; bun run dev",
    "api:dev": "cd api ; bun run start:dev",
    "build": "bun run build:packages && bun run build:api && bun run build:web",
    "build:packages": "bun run --filter './packages/*' build",
    "build:api": "bun run --filter api build",
    "build:web": "bun run --filter my-v0-project build",
    "build:mobile": "cd our-app ; bun run build:mobile",
    "build:android": "cd our-app ; bun run build && bun run cap:sync:android",
    "build:ios": "cd our-app ; bun run build && bun run cap:sync:ios",
    "start": "bun run --filter api start:prod",
    "start:web": "bun run --filter my-v0-project start",
    "lint": "bun run --filter \"*\" lint",
    "lint:api": "bun run --filter api lint",
    "lint:web": "bun run --filter my-v0-project lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "migration:generate": "cd api && bun run migration:generate",
    "migration:run": "cd api && bun run migration:run",
    "migration:revert": "cd api && bun run migration:revert",
    "generate:ui-client": "orval --config ./orval.config.ts",
    "mobile:init": "cd our-app ; bun run cap:init",
    "mobile:add:android": "cd our-app ; bun run cap:add:android",
    "mobile:add:ios": "cd our-app ; bun run cap:add:ios",
    "mobile:sync": "cd our-app ; bun run cap:sync",
    "mobile:sync:android": "cd our-app ; bun run cap:sync:android",
    "mobile:sync:ios": "cd our-app ; bun run cap:sync:ios",
    "mobile:open:android": "cd our-app ; bun run cap:open:android",
    "mobile:open:ios": "cd our-app ; bun run cap:open:ios",
    "mobile:run:android": "cd our-app ; bun run cap:run:android",
    "mobile:run:ios": "cd our-app ; bun run cap:run:ios",
    "setup": "bun scripts/script_list/setup.ts",
    "setup:java": "powershell -ExecutionPolicy Bypass -File ./packages/scripts/setup-java-env.ps1",
    "clean": "bun run --filter \"*\" --parallel exec rm -rf node_modules dist .next coverage",
    "clean:install": "bun run clean && rm -rf node_modules && bun install",
    "scripts": "node scripts/index.js",
    "docker:build": "docker build -t businesspro-api:local .",
    "docker:run": "docker run --rm -p 8000:8000 --env-file api/.env -e PORT=8000 --name businesspro-local businesspro-api:local",
    "docker:preview": "docker build -t businesspro-api:local . && docker run --rm -p 8000:8000 --env-file api/.env -e PORT=8000 --name businesspro-local businesspro-api:local",
    "docker:stop": "docker stop businesspro-local",
    "docker:clean": "docker rmi businesspro-api:local"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "orval": "^7.16.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@nestjs/event-emitter": "^3.0.1",
    "ajv": "^8.18.0",
    "helmet": "^8.1.0",
    "i18next": "^25.8.14",
    "react-i18next": "^16.5.6"
  }
}
